# 从 https://my.telegram.org 获取
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 登录手机号（含国际区号，如 +8613800138000）
TELEGRAM_PHONE=+8613800138000

# 飞书自定义机器人 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 图片/贴纸转发（可选）：Lark 开放平台应用的 App ID 和 Secret
# 在 https://open.larksuite.com/app 创建企业自建应用，启用机器人能力，
# 开通 im:resource 权限，发布后在「凭证与基础信息」获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 国际版 Lark 一般留空即可自动识别；国内飞书可填 https://open.feishu.cn/open-apis
FEISHU_API_BASE=

# 大陆服务器连接 Telegram 需要代理（Mac 本地一般留空）
# 格式: socks5://127.0.0.1:1080  或  socks5://user:pass@host:1080
TELEGRAM_PROXY=

# 群聊监听模式:
#   manual=GROUP_CHATS 列表内全部监听（忽略静音）
#   manual_unmuted=GROUP_CHATS 列表内且未静音才监听（推荐）
#   unmuted=所有未静音群（忽略 GROUP_CHATS）
GROUP_MODE=manual_unmuted

# unmuted / manual_unmuted 模式下：静音状态刷新间隔（秒），默认 300；设为 0 则仅启动时读取
GROUP_REFRESH_INTERVAL=300

# manual / manual_unmuted 模式下：监听的群聊 ID 或 @username，多个用英文逗号分隔
# unmuted 模式下：此配置无效，自动监听所有未静音群
# 私聊消息默认全部监听，无需配置
GROUP_CHATS=-1001234567890,@my_group_username

# 可选：会话文件名（默认 telegram_session）
SESSION_NAME=telegram_session

# 可选：断线重连间隔（秒，默认 10）
RECONNECT_INTERVAL=10

# 可选：日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# true=只转发别人发的消息  false=连自己发的也转发（自测时可设 false）
INCOMING_ONLY=true

# ---- 飞书回复 TG（一群对应一群）----
# 启用后：TG 群消息发到对应飞书群；在飞书群里直接发消息即可回到 TG 群
FEISHU_REPLY_ENABLED=false
# TG群ID:飞书群chat_id，多个用逗号分隔（运行 ./start.sh feishu-chats 获取 chat_id）
# 示例：I组1573对接牛哥、灰灰以及大脸喵
FEISHU_CHAT_MAP=-5289292369:oc_群1chatid,-5005244212:oc_群2chatid
# 可选：所有 TG 私聊汇总到一个飞书群；回复时需「回复」某人的消息卡片
FEISHU_DM_CHAT_ID=
# 事件回调（服务器需公网 HTTPS 可访问，本地测试可用 ngrok）
FEISHU_EVENT_HOST=0.0.0.0
FEISHU_EVENT_PORT=8080
FEISHU_EVENT_PATH=/feishu/event
# Lark 开放平台 -> 事件订阅 -> Verification Token
FEISHU_VERIFICATION_TOKEN=
# 可选：事件 Encrypt Key（平台启用加密时填写）
FEISHU_ENCRYPT_KEY=
# 可选：允许操作的飞书用户 open_id，逗号分隔；留空=不限制
FEISHU_ALLOWED_OPEN_IDS=
