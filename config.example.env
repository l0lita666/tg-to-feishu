# 从 https://my.telegram.org 获取
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# 登录手机号（含国际区号，如 +8613800138000）
TELEGRAM_PHONE=+8613800138000

# 飞书自定义机器人 Webhook 地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# 图片/贴纸转发（可选）：Lark 开放平台应用的 App ID 和 Secret
# 在 https://open.larksuite.com/app 创建企业自建应用，启用机器人能力，
# 开通 im:resource 权限，发布后在「凭证与基础信息」获取
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 国际版 Lark 一般留空即可自动识别；国内飞书可填 https://open.feishu.cn/open-apis
FEISHU_API_BASE=

# 大陆服务器连接 Telegram 需要代理（Mac 本地一般留空）
# 格式: socks5://127.0.0.1:1080  或  socks5://user:pass@host:1080
TELEGRAM_PROXY=

# 群聊监听模式: manual=手动指定群  unmuted=所有未开静音的群
GROUP_MODE=manual

# unmuted 模式下：静音状态刷新间隔（秒），默认 300；设为 0 则仅启动时读取
GROUP_REFRESH_INTERVAL=300

# manual 模式下：监听的群聊 ID 或 @username，多个用英文逗号分隔
# unmuted 模式下：此配置无效，自动监听所有未静音群
# 私聊消息默认全部监听，无需配置
GROUP_CHATS=-1001234567890,@my_group_username

# 可选：会话文件名（默认 telegram_session）
SESSION_NAME=telegram_session

# 可选：断线重连间隔（秒，默认 10）
RECONNECT_INTERVAL=10

# 可选：日志级别 DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# true=只转发别人发的消息  false=连自己发的也转发（自测时可设 false）
INCOMING_ONLY=true
